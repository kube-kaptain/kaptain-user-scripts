#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# Rotate the encryption key for secrets.
# Decrypts all secrets with the old key and re-encrypts with a new key.
# By default generates a new key; use --ask-for-key to supply your own.
#
# Usage: kaptain-rotate-key-for-secrets [--dir DIR] [--ask-for-key] [--new-type TYPE] [--output FILE]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SECRETS_DIR="${KAPTAIN_USER_SCRIPTS_SECRETS_DIR:-src/secrets}"
ASK_FOR_KEY=false
NEW_TYPE=""
OUTPUT=""

usage() {
  echo "Usage: kaptain rotate-key-for-secrets [--dir DIR] [--ask-for-key] [--new-type TYPE] [--output FILE]"
  echo ""
  echo "Rotate the encryption key for secrets."
  echo ""
  echo "Options:"
  echo "  --dir DIR         Secrets directory (default: src/secrets)"
  echo "  --ask-for-key     Prompt for new key instead of generating"
  echo "  --new-type TYPE   Migrate to a different encryption type"
  echo "  --output FILE     Write generated key to file (default: target/keygen/new.key)"
  echo "  -h, --help        Show this help"
}

# Parse arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --dir)
      if [[ $# -lt 2 ]]; then
        echo "ERROR: --dir requires a value" >&2
        exit 1
      fi
      SECRETS_DIR="$2"
      shift 2
      ;;
    --ask-for-key)
      ASK_FOR_KEY=true
      shift
      ;;
    --new-type)
      if [[ $# -lt 2 ]]; then
        echo "ERROR: --new-type requires a value" >&2
        exit 1
      fi
      NEW_TYPE="$2"
      shift 2
      ;;
    --output)
      if [[ $# -lt 2 ]]; then
        echo "ERROR: --output requires a value" >&2
        exit 1
      fi
      OUTPUT="$2"
      shift 2
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

# Reject absolute paths for --dir
if [[ "${SECRETS_DIR}" == /* ]]; then
  echo "ERROR: --dir must be a relative path, i.e. a sub path of this repo" >&2
  exit 1
fi

if [[ ! -d "${SECRETS_DIR}" ]]; then
  echo "ERROR: Secrets directory not found: ${SECRETS_DIR}" >&2
  exit 1
fi

# Validate --output early (only when generating a key)
if [[ "${ASK_FOR_KEY}" == "false" ]]; then
  output_file="${OUTPUT:-target/keygen/new.key}"
  if [[ "${output_file}" == /* ]]; then
    echo "ERROR: --output must be a relative path" >&2
    exit 1
  fi
  if [[ -e "${output_file}" ]]; then
    echo "ERROR: Output file already exists: ${output_file}" >&2
    exit 1
  fi
  output_dir=$(dirname "${output_file}")
  if [[ -n "${OUTPUT}" && ! -d "${output_dir}" ]]; then
    echo "ERROR: Output directory does not exist: ${output_dir}" >&2
    exit 1
  fi
fi

# Discover valid encryption suffixes from available encrypt scripts
ENC_SUFFIXES=()
for script in "${SCRIPT_DIR}"/kaptain-encrypt-*; do
  if [[ -x "${script}" ]]; then
    suffix="${script##*kaptain-encrypt-}"
    ENC_SUFFIXES+=("${suffix}")
  fi
done

if [[ ${#ENC_SUFFIXES[@]} -eq 0 ]]; then
  echo "ERROR: No encryption scripts found" >&2
  exit 1
fi

# --- Pre-flight checks ---

# Check no .txt or .raw files
txt_files=()
while IFS= read -r -d '' file; do
  txt_files+=("$file")
done < <(find "${SECRETS_DIR}" -name "*.txt" -type f -print0 2>/dev/null)

raw_files=()
while IFS= read -r -d '' file; do
  raw_files+=("$file")
done < <(find "${SECRETS_DIR}" -name "*.raw" -type f -print0 2>/dev/null)

if [[ ${#txt_files[@]} -gt 0 || ${#raw_files[@]} -gt 0 ]]; then
  echo "ERROR: Secrets directory is not clean" >&2
  echo "Found ${#txt_files[@]} .txt and ${#raw_files[@]} .raw file(s)" >&2
  echo "Run 'kaptain clean secrets' first" >&2
  exit 1
fi

# Find all encrypted files and determine current type
current_type=""
enc_files=()
for suffix in "${ENC_SUFFIXES[@]}"; do
  while IFS= read -r -d '' file; do
    enc_files+=("$file")
    if [[ -z "${current_type}" ]]; then
      current_type="${suffix}"
    elif [[ "${current_type}" != "${suffix}" ]]; then
      echo "ERROR: Mixed encryption types found (${current_type} and ${suffix})" >&2
      echo "All secrets must use the same encryption type" >&2
      exit 1
    fi
  done < <(find "${SECRETS_DIR}" -name "*.${suffix}" -type f -print0 2>/dev/null)
done

if [[ ${#enc_files[@]} -eq 0 ]]; then
  echo "ERROR: No encrypted files found in ${SECRETS_DIR}" >&2
  exit 1
fi

# Determine target type
target_type="${NEW_TYPE:-${current_type}}"

# Validate target type is known
type_valid=false
for suffix in "${ENC_SUFFIXES[@]}"; do
  if [[ "${suffix}" == "${target_type}" ]]; then
    type_valid=true
    break
  fi
done
if [[ "${type_valid}" == "false" ]]; then
  echo "ERROR: Unknown encryption type: ${target_type}" >&2
  echo "Available types: ${ENC_SUFFIXES[*]}" >&2
  exit 1
fi

echo "Rotating key for ${#enc_files[@]} ${current_type} file(s) in ${SECRETS_DIR}"
if [[ "${current_type}" != "${target_type}" ]]; then
  echo "Migrating encryption type: ${current_type} → ${target_type}"
fi

# --- Set up temp directory for key files ---

ROTATE_TMP=$(mktemp -d)
trap 'rm -rf "${ROTATE_TMP}"' EXIT

old_key_file="${ROTATE_TMP}/old.key"
new_key_file="${ROTATE_TMP}/new.key"

# --- Collect keys ---

# Old key
read -r -s -p "Enter current key: " old_key
echo
echo "${old_key}" > "${old_key_file}"
chmod 600 "${old_key_file}"

# New key
if [[ "${ASK_FOR_KEY}" == "true" ]]; then
  read -r -s -p "Enter new key: " new_key
  echo
  read -r -s -p "Enter new key again: " new_key_confirm
  echo
  if [[ "${new_key}" != "${new_key_confirm}" ]]; then
    echo "ERROR: New keys do not match" >&2
    exit 1
  fi
  echo "${new_key}" > "${new_key_file}"
  chmod 600 "${new_key_file}"
else
  # Generate new key via keygen
  keygen_type="plain"
  if [[ "${target_type}" == "age" ]]; then
    keygen_type="age"
  fi
  if ! "${SCRIPT_DIR}/kaptain-keygen" --type "${keygen_type}" --output "${new_key_file}" > /dev/null 2>&1; then
    echo "ERROR: Failed to generate new key" >&2
    exit 1
  fi
fi

# --- Decrypt all with old key ---

echo ""
echo "Decrypting with current key..."
if ! "${SCRIPT_DIR}/kaptain-decrypt-${current_type}" --dir "${SECRETS_DIR}" --key-file "${old_key_file}"; then
  echo "" >&2
  echo "Cleaning up decrypted files..." >&2
  find "${SECRETS_DIR}" -name "*.txt" -type f -delete 2>/dev/null || true
  echo "Key rotation aborted. No files were changed." >&2
  exit 1
fi

# --- Rename .txt to .raw ---

echo ""
echo "Preparing for re-encryption..."
while IFS= read -r -d '' txt_file; do
  mv "${txt_file}" "${txt_file%.txt}.raw"
done < <(find "${SECRETS_DIR}" -name "*.txt" -type f -print0)

# --- Delete old encrypted files ---
# Must remove before re-encrypting so encrypt scripts don't validate
# the new key against old encrypted files (which would fail)

for enc_file in "${enc_files[@]}"; do
  rm -f "${enc_file}"
done

# --- Re-encrypt all with new key ---

echo ""
echo "Re-encrypting with new key..."
if ! "${SCRIPT_DIR}/kaptain-encrypt-${target_type}" --dir "${SECRETS_DIR}" --key-file "${new_key_file}"; then
  echo "" >&2
  echo "ERROR: Re-encryption failed" >&2
  echo "Your decrypted files are still available as .raw files in ${SECRETS_DIR}" >&2
  if [[ "${ASK_FOR_KEY}" == "false" ]]; then
    # Save the generated key so the user can retry
    mkdir -p "$(dirname "${output_file}")"
    cp "${new_key_file}" "${output_file}"
    chmod 600 "${output_file}"
    echo "New key saved to: ${output_file}" >&2
  fi
  echo "You can retry encryption manually." >&2
  exit 1
fi

# --- Clean up .raw files ---

find "${SECRETS_DIR}" -name "*.raw" -type f -delete 2>/dev/null || true

# --- Output new key ---

echo ""
echo "Key rotation complete."

if [[ "${ASK_FOR_KEY}" == "false" ]]; then
  mkdir -p "$(dirname "${output_file}")"
  cp "${new_key_file}" "${output_file}"
  chmod 600 "${output_file}"
  echo ""
  echo "New key written to: ${output_file}"
  echo ""
  echo "Keep this key safe - store it in a password manager..."
  echo "... or secure location with correct permissions/umask."
fi
